datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}


generator client {
  provider = "prisma-client-js"
}


model User {

  id Int @id @default(autoincrement())

  username String @unique @db.VarChar(15)

  password String @unique @db.VarChar(150)

}


model Pokemons {

  id Int @id @default(autoincrement())

  capt String @default("")

}